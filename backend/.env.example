# Neon PostgreSQL — copy from your Neon dashboard → Connection string
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require

ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=

ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
AI_RATE_LIMIT=60/minute
CACHE_TTL_HOURS=24
LOG_LEVEL=INFO

# Redis (optional — falls back to in-memory cache if unset)
REDIS_URL=redis://localhost:6379

# SMTP settings for pipeline failure alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=your-email@gmail.com
