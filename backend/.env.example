# Neon PostgreSQL — copy from your Neon dashboard → Connection string
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require&channel_binding=require

ANTHROPIC_API_KEY=sk-ant-...
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
AI_RATE_LIMIT=10/minute
CACHE_TTL_HOURS=24
LOG_LEVEL=INFO
+
+# SMTP Settings for Failure Alerts
+SMTP_HOST=smtp.gmail.com
+SMTP_PORT=587
+SMTP_USERNAME=your-email@gmail.com
+SMTP_PASSWORD=your-app-password
+ALERT_EMAIL=your-email@gmail.com
+
